rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Default
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Helper functions
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && isEmailVerified() && (
        request.auth.token.email == "sunilas1711@gmail.com" ||
        request.auth.token.email == "Sunilas1711@gmail.com" ||
        request.auth.token.email == "maintenancemasters2001@gmail.com" ||
        request.auth.token.email == "deathrb12@gmail.com"
      );
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() 
        && isValidProject(incoming());
      allow update: if isAdmin() 
        && isValidProject(incoming())
        && (!existing().keys().hasAll(['createdAt']) || incoming().createdAt == existing().createdAt);
      allow delete: if isAdmin();
    }

    match /project/{projectId} {
      allow read: if true;
      allow create: if isAdmin() 
        && isValidProject(incoming());
      allow update: if isAdmin() 
        && isValidProject(incoming())
        && (!existing().keys().hasAll(['createdAt']) || incoming().createdAt == existing().createdAt);
      allow delete: if isAdmin();
    }

    match /oroject/{projectId} {
      allow read: if true;
      allow create: if isAdmin() 
        && isValidProject(incoming());
      allow update: if isAdmin() 
        && isValidProject(incoming())
        && (!existing().keys().hasAll(['createdAt']) || incoming().createdAt == existing().createdAt);
      allow delete: if isAdmin();
    }

    // Strict validation matcher of all required fields & field bounds to thwart Denial-of-Wallet attacks
    function isValidProject(data) {
      return data.keys().hasAll(['id', 'title', 'subtitle', 'category', 'image', 'location', 'year', 'aspectRatio', 'isFeatured', 'createdAt'])
        && data.id is string
        && data.title is string
        && data.subtitle is string
        && data.category is string
        && data.image is string
        && data.location is string
        && data.year is string
        && data.aspectRatio is string
        && data.isFeatured is bool
        && (!data.keys().hasAny(['num']) || (data.num is int || data.num is float));
    }
  }
}
